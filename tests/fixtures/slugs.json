      ],
      "slug": "a",
      "expected": "a-3"
    },
    {
      "existing": [
        "a",
        "a-1"
      ],
      "slug": "a",
      "expected": "a-2"
    },
    {
      "existing": [
        "a-1"
      ],
      "slug": "a",
      "expected": "a"
    }
  ]
}
